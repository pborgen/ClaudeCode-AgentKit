#!/usr/bin/env bash
# Bootstrap a Claude Code dev box: swap, AWS CLI, Tailscale (with Tailscale SSH),
# Node.js, Claude Code, optional dotfiles, and an idle auto-shutdown timer.
# Runs once at first boot as root.
set -euxo pipefail

# --- Swap: 2GB RAM is tight for Node builds; back it with 4GB of swap ---
if ! swapon --show | grep -q '/swapfile'; then
  fallocate -l 4G /swapfile || dd if=/dev/zero of=/swapfile bs=1M count=4096
  chmod 600 /swapfile
  mkswap /swapfile
  swapon /swapfile
  echo '/swapfile none swap sw 0 0' >> /etc/fstab
fi

export DEBIAN_FRONTEND=noninteractive
apt-get update -y
apt-get install -y curl git build-essential ca-certificates gnupg ripgrep unzip jq tmux

# --- AWS CLI v2 (used by the idle-shutdown timer to stop this instance) ---
curl -fsSL "https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip" -o /tmp/awscliv2.zip
unzip -q /tmp/awscliv2.zip -d /tmp
/tmp/aws/install --update
rm -rf /tmp/aws /tmp/awscliv2.zip

# --- Tailscale: join the tailnet and enable Tailscale SSH ---
# `--ssh` lets anyone on your tailnet SSH in, authenticated by tailnet identity,
# so there are NO ssh keys to manage. Connect with: ssh ubuntu@${hostname}
curl -fsSL https://tailscale.com/install.sh | sh
tailscale up \
  --authkey='${tailscale_auth_key}' \
  --hostname='${hostname}' \
  --ssh \
  --accept-routes

# --- Node.js LTS (required by Claude Code) ---
curl -fsSL https://deb.nodesource.com/setup_22.x | bash -
apt-get install -y nodejs

# --- Claude Code, installed for the ubuntu user (not root) ---
sudo -iu ubuntu bash <<'EOF'
set -eux
npm config set prefix '/home/ubuntu/.npm-global'
if ! grep -q '.npm-global/bin' /home/ubuntu/.bashrc; then
  echo 'export PATH=/home/ubuntu/.npm-global/bin:$PATH' >> /home/ubuntu/.bashrc
fi
export PATH=/home/ubuntu/.npm-global/bin:$PATH
# Claude Code, plus ccmanager (a TUI to create/switch/manage parallel sessions).
npm install -g @anthropic-ai/claude-code ccmanager

# Auto-attach tmux on interactive login so sessions survive phone/SSH disconnects.
if ! grep -q 'tmux attach -t main' /home/ubuntu/.bashrc; then
  cat >> /home/ubuntu/.bashrc <<'BRC'

# --- Auto-attach tmux on interactive login (sessions survive disconnects) ---
if command -v tmux >/dev/null 2>&1 && [ -z "$${TMUX:-}" ] && [ -t 1 ] && [[ $- == *i* ]]; then
  tmux attach -t main 2>/dev/null || tmux new-session -s main
fi
BRC
fi
EOF

# --- Optional: git identity + dotfiles, so the box feels like home ---
%{ if git_user_name != "" ~}
sudo -u ubuntu git config --global user.name '${git_user_name}'
%{ endif ~}
%{ if git_user_email != "" ~}
sudo -u ubuntu git config --global user.email '${git_user_email}'
%{ endif ~}
%{ if dotfiles_repo != "" ~}
sudo -iu ubuntu git clone '${dotfiles_repo}' /home/ubuntu/.dotfiles || true
if [ -x /home/ubuntu/.dotfiles/install.sh ]; then
  sudo -iu ubuntu /home/ubuntu/.dotfiles/install.sh || true
fi
%{ endif ~}

# --- Idle auto-shutdown: stop the box after N idle minutes (cost safety net) ---
if [ ${idle_shutdown_minutes} -gt 0 ]; then
  cat > /usr/local/bin/claude-dev-idle.sh <<'IDLE'
#!/usr/bin/env bash
# Stop this dev box when it is TRULY idle, but keep it alive while real work or
# an attached session exists. The box is considered "alive" if ANY of:
#   1. a Claude Code session is running (even detached inside tmux) -- never kill work
#   2. a tmux client is currently attached (you are actively connected)
#   3. an interactive shell is attached that is NOT just a detached tmux pane
#      (raw SSH / console -- detected by walking process ancestry to sshd/tailscaled)
# Otherwise increment the idle counter and stop the instance once the window passes.
#
# NOTE: `who` is intentionally NOT used -- Tailscale SSH does not write utmp.
set -uo pipefail
IDLE_MINUTES=${idle_shutdown_minutes}
INTERVAL_MIN=5
NEEDED=$(( (IDLE_MINUTES + INTERVAL_MIN - 1) / INTERVAL_MIN ))
STATE=/var/run/claude-dev-idle.count
DEV_USER=ubuntu
[ -f "$STATE" ] || echo 0 > "$STATE"

alive() {
  # 1. A Claude Code session running anywhere. The CLI is a native binary invoked
  #    via a symlink, so its argv is just "claude" -- `pgrep -f <path>` does NOT
  #    work. Match comm=claude and confirm the exe resolves into the package.
  local cpid cexe
  for cpid in $(pgrep -x claude 2>/dev/null); do
    cexe=$(readlink "/proc/$cpid/exe" 2>/dev/null)
    case "$cexe" in
      */claude-code/*) return 0 ;;
      "")              return 0 ;;
    esac
  done

  # 2. A tmux client is attached (query the dev user's tmux server).
  if [ -n "$(sudo -u "$DEV_USER" tmux list-clients 2>/dev/null)" ]; then return 0; fi

  # 3. An interactive shell attached via a real connection (not a detached tmux
  #    pane). Walk each pty process up its parents: hitting sshd/tailscaled means
  #    attached; hitting the tmux server means it's a pane, not a live session.
  local p ppid comm cur
  for p in $(ps -eo pid=,tty= | awk '$2 ~ /^pts\// {print $1}'); do
    cur="$p"
    while [ "$${cur:-0}" -gt 1 ] 2>/dev/null; do
      read -r ppid comm < <(ps -o ppid=,comm= -p "$cur" 2>/dev/null)
      [ -z "$${ppid:-}" ] && break
      case "$comm" in
        sshd|tailscaled) return 0 ;;
        tmux*) break ;;
      esac
      cur="$ppid"
    done
  done

  return 1
}

if alive; then
  echo 0 > "$STATE"
  exit 0
fi

count=$(( $(cat "$STATE") + 1 ))
echo "$count" > "$STATE"
if [ "$count" -ge "$NEEDED" ]; then
  TOKEN=$(curl -sX PUT http://169.254.169.254/latest/api/token -H 'X-aws-ec2-metadata-token-ttl-seconds: 60')
  IID=$(curl -s -H "X-aws-ec2-metadata-token: $TOKEN" http://169.254.169.254/latest/meta-data/instance-id)
  REGION=$(curl -s -H "X-aws-ec2-metadata-token: $TOKEN" http://169.254.169.254/latest/meta-data/placement/region)
  logger -t claude-dev-idle "idle ~$${IDLE_MINUTES}m (no claude/attached session), stopping $IID"
  aws ec2 stop-instances --instance-ids "$IID" --region "$REGION"
fi
IDLE
  chmod +x /usr/local/bin/claude-dev-idle.sh

  cat > /etc/systemd/system/claude-dev-idle.service <<'UNIT'
[Unit]
Description=Stop the dev box when idle
[Service]
Type=oneshot
ExecStart=/usr/local/bin/claude-dev-idle.sh
UNIT

  cat > /etc/systemd/system/claude-dev-idle.timer <<'UNIT'
[Unit]
Description=Check idle state every 5 minutes
[Timer]
OnBootSec=15min
OnUnitActiveSec=5min
[Install]
WantedBy=timers.target
UNIT

  systemctl daemon-reload
  systemctl enable --now claude-dev-idle.timer
fi

echo "provisioning complete" > /var/log/claude-dev-provision.done
